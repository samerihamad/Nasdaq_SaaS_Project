# انسخ هذا الملف إلى ".env" واملأ القيم الحقيقية.
# لا ترفع ".env" إلى GitHub.

# =========================
# Broker / Capital.com
# =========================
CAPITAL_API_KEY=your_capital_api_key
CAPITAL_EMAIL=your_email@example.com
CAPITAL_PASSWORD=your_capital_password
CAPITAL_IS_DEMO=true
# Legacy compatibility (connection_test.py fallback)
CAPITAL_IDENTIFIER=

# Optional dedicated scanner identity (otherwise falls back to CAPITAL_*)
MARKET_DATA_CAPITAL_API_KEY=
MARKET_DATA_CAPITAL_EMAIL=
MARKET_DATA_CAPITAL_PASSWORD=
MARKET_DATA_CAPITAL_IS_DEMO=
MARKET_DATA_TIMEOUT_SEC=20
MARKET_DATA_SESSION_TTL_SEC=45

# =========================
# Telegram / Admin
# =========================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
ADMIN_CHAT_ID=your_admin_chat_id
# Required for admin HTTP endpoints in api/app.py
ADMIN_API_SECRET=replace_with_strong_secret

# =========================
# Security / Encryption
# =========================
ENCRYPTION_KEY=your_base64_encryption_key

# =========================
# Logging / Engine
# =========================
ENGINE_LOG_ROOT=logs
REJECTION_SUPPRESSION_NOTICE_COOLDOWN_SEC=1800
EXECUTION_REJECTION_NOTIFY_COOLDOWN_SEC=600
SUPPRESS_EXPECTED_REJECTION_TELEGRAM=true

# =========================
# Signal Profiles (Phase 8)
# =========================
SIGNAL_PROFILE=FAST
FAST_MIN_CONFIDENCE=63
GOLDEN_MIN_CONFIDENCE=67
FAST_MR_MIN_SCORE=65
GOLDEN_MR_MIN_SCORE=74
FAST_MOM_MIN_SCORE=68
GOLDEN_MOM_MIN_SCORE=78
FAST_MR_RSI_EXTREME_OVERSOLD=30
FAST_MR_RSI_EXTREME_OVERBOUGHT=70
FAST_MOM_ADX_THRESHOLD=18
FAST_MOM_VOL_RATIO=1.0
FAST_MOM_VOL_RATIO_HIGH_RSI=0.8
FAST_MOM_RSI_VOL_TIER_HIGH=70
FAST_MOM_RSI_BUY_MAX=77
FAST_MOM_LOW_VOL_AI_MIN=65

# =========================
# Market Structure / Strategy Filters
# =========================
ENABLE_MARKET_STRUCTURE_FILTERS=true
ENABLE_PREMIUM_DISCOUNT_FILTER=true
ENABLE_LIQUIDITY_MAP_FILTER=true
MARKET_STRUCTURE_NO_TRADE_ZONE_PCT=0.14
MARKET_STRUCTURE_HTF_LOOKBACK=80
LIQUIDITY_OPENING_RANGE_BARS=6
ENABLE_STRUCTURAL_REJECTION_NOTIFY=true
STRUCTURAL_REJECTION_NOTIFY_COOLDOWN_SEC=1800
STRUCTURAL_REJECTION_NOTIFY_MAX_PER_CYCLE=5
FINAL_SYNC_FALLBACK_ENABLED=true

# =========================
# Limit Order Policy (Sprint 2)
# =========================
ENABLE_LIMIT_ORDER_MODE=true
LIMIT_ORDER_TTL_BARS=4
LIMIT_ORDER_BAR_MINUTES=15
LIMIT_ORDER_MOMENTUM_RETRACE=0.618
LIMIT_ORDER_MEANREV_ATR_OFFSET=0.20
LIMIT_ORDER_ALLOW_MARKET_FALLBACK=false

# =========================
# AI Gatekeeper
# =========================
AI_MIN_PROB_RF=62.0
AI_MIN_PROB_MOMENTUM=65.0
AI_MIN_PROB_MEANREV=64.0
AI_SOFT_OVERRIDE_CONFIDENCE=63.0
AI_SOFT_OVERRIDE_MIN_PROB=40.0
ENABLE_AI_SOFT_OVERRIDE=false
ENABLE_MS_SCORE_AI_INTEGRATION=true
MS_SCORE_AI_NEUTRAL=50.0
MS_SCORE_AI_SCALE=0.18
MS_SCORE_AI_MAX_IMPACT=8.0

# =========================
# Deep Direction Model (Phase 7)
# =========================
ENABLE_DEEP_DIRECTION_MODEL=false
DEEP_DIRECTION_MODEL_KIND=lstm
DEEP_DIRECTION_TIMEFRAME=15m
DEEP_DIRECTION_SEQ_LEN=64
DEEP_DIRECTION_LABEL_HORIZON=8
DEEP_DIRECTION_LABEL_THRESHOLD=0.012
ENABLE_DEEP_DIRECTION_INFERENCE=false
DEEP_DIRECTION_INFERENCE_KIND=lstm

# =========================
# Autonomous AI Training
# =========================
# Master switch for the autonomous training framework
ENABLE_AUTONOMOUS_TRAINING=false

# Cron-like schedule (UTC)
ENABLE_AUTONOMOUS_SCHEDULED_TRAINING=true
AUTOTRAIN_SCHEDULER_POLL_SEC=60
AUTOTRAIN_DAILY_UTC_HOUR=2
AUTOTRAIN_DAILY_UTC_MINUTE=15
AUTOTRAIN_WEEKLY_DAY=sun
AUTOTRAIN_WEEKLY_UTC_HOUR=3
AUTOTRAIN_WEEKLY_UTC_MINUTE=30

# Training sizing / cadence
AUTOTRAIN_MAX_SYMBOLS_PER_RUN=20
AUTOTRAIN_EPOCHS=20
AUTOTRAIN_AUTO_MAX_MODEL_AGE_HOURS=168

# Self-learning loop from closed trade outcomes
ENABLE_AUTONOMOUS_SELF_LEARNING=true
AUTOTRAIN_SELF_LEARNING_INTERVAL_SEC=21600
AUTOTRAIN_SELF_LEARNING_MIN_SAMPLES=25
AUTOTRAIN_SELF_LEARNING_SYMBOLS_PER_RUN=6
AUTOTRAIN_SELF_LEARNING_EPOCHS=10

# Monitoring / artifacts
AUTOTRAIN_NOTIFY_ADMIN=true
AUTOTRAIN_LOG_ROOT=logs/ai_training

# =========================
# News / Earnings
# =========================
NEWS_API_KEY=
FMP_API_KEY=
EARNINGS_TIMEOUT_SEC=15
EARNINGS_CACHE_TTL_SEC=1800

# =========================
# Institutional Risk Controls
# =========================
WEEKLY_DRAWDOWN_LIMIT=10.0
MAX_SYMBOL_EXPOSURE_FRACTION=0.35
MAX_SECTOR_EXPOSURE_FRACTION=0.55
MAX_TOTAL_EXPOSURE_MULT=1.00
MAX_TRADES_PER_SYMBOL_DAY=2
MAX_TRADES_PER_DAY_RISK=5
MARGIN_CALL_BUFFER_PCT=0.15
MAX_STOP_LOSS_PCT=0.06
ATR_SL_MULT_LOW_VOL=2.2
ATR_SL_MULT_HIGH_VOL=1.4
VOL_BAND_MULT=2.2
LIQUIDITY_SL_BUFFER_ATR=0.35
SWING_LOOKBACK_BARS=20

# =========================
# Close Sync / Reconciliation
# =========================
ENABLE_CLOSE_PENDING_NOTIFY=false
CLOSE_SYNC_RETRY_COOLDOWN_SEC=30
CLOSE_SYNC_MAX_ATTEMPTS=120
VERIFY_CLOSE_MAX_POLLS=10
VERIFY_CLOSE_POLL_SEC=0.6
VERIFY_CLOSE_CONSECUTIVE_ABSENT=2

# =========================
# Cloud Backup (Google Drive / Dropbox)
# =========================
BACKUP_PROVIDER=gdrive
DROPBOX_ACCESS_TOKEN=

GDRIVE_AUTH=oauth
GDRIVE_FOLDER_ID=your_drive_folder_id
GDRIVE_SUPPORTS_ALL_DRIVES=false

# OAuth mode
GDRIVE_OAUTH_CLIENT_JSON=/absolute/path/to/client_secret.json
GDRIVE_OAUTH_TOKEN_JSON=/absolute/path/to/gdrive_token.json
GDRIVE_OAUTH_CONSOLE=false
GDRIVE_OAUTH_PORT=8080

# Service account mode
GOOGLE_SERVICE_ACCOUNT_JSON=/absolute/path/to/service_account.json

# =========================
# Admin Email Notifications (optional)
# =========================
ADMIN_EMAIL=admin@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# If empty, notifier falls back to ADMIN_EMAIL
SMTP_USER=
SMTP_PASS=

# =========================
# Admin WhatsApp via Twilio (optional)
# =========================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886
ADMIN_WHATSAPP=

# =========================
# Watchdog
# =========================
WATCHDOG_AUTO_RESTART=false
