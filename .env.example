# انسخ هذا الملف إلى اسم ".env" وعبّئ القيم الحقيقية على جهازك أو على الـ VPS.
# لا ترفع ملف .env إلى GitHub — هو مُستبعد في .gitignore.
# هذا الملف (.env.example) يُرفع للمستودع كقالب فقط (بدون أسرار).

# Capital.com API Configuration
CAPITAL_API_KEY=your_capital_api_key
CAPITAL_EMAIL=your_email@example.com
CAPITAL_PASSWORD=your_capital_password
CAPITAL_IS_DEMO=true
# Optional dedicated scanner identity (shared market-data service account)
MARKET_DATA_CAPITAL_API_KEY=
MARKET_DATA_CAPITAL_EMAIL=
MARKET_DATA_CAPITAL_PASSWORD=
MARKET_DATA_CAPITAL_IS_DEMO=

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
ADMIN_CHAT_ID=your_admin_chat_id
SUPPORT_USERNAME=your_support_username

# ── Encryption ─────────────────────────────────────────────────────────────
ENCRYPTION_KEY=your_base64_encryption_key
# النسخ السحابي: gdrive أو dropbox فقط (لا تضع رابط Drive في BACKUP_PROVIDER)
BACKUP_PROVIDER=gdrive
# المعرف فقط من الرابط بعد /folders/
GDRIVE_FOLDER_ID=your_drive_folder_id
# oauth = Gmail شخصي (موصى به) | service_account = Workspace/متقدم
GDRIVE_AUTH=oauth
# مثال VPS: /home/user/Nasdaq_SaaS_Project/config/client_secret....json
GDRIVE_OAUTH_CLIENT_JSON=/path/to/client_secret.json
# GDRIVE_OAUTH_TOKEN_JSON=/path/to/gdrive_token.json
# أول مرة على VPS بدون متصفح: GDRIVE_OAUTH_CONSOLE=1 python -m utils.backup (الصق رابط إعادة التوجيه أو الكود)
# GDRIVE_OAUTH_CONSOLE=1
# GDRIVE_OAUTH_PORT=8080
# إن استخدمت service_account بدل oauth:
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service_account.json
DROPBOX_ACCESS_TOKEN=

# News API
NEWS_API_KEY=your_news_api_key

# Earnings calendar + market-cap fallback providers (scanner filters)
# Primary provider uses NASDAQ endpoints (no key).
# Optional fallback key (used for earnings + market-cap profile lookup):
FMP_API_KEY=
EARNINGS_TIMEOUT_SEC=15
EARNINGS_CACHE_TTL_SEC=1800

# ── Admin Email Notifications (optional) ────────────────────────────────────
# يُرسل عند رفع العميل لصورة الدفع (ليس عند /start فقط).
# Gmail: فعّل التحقق بخطوتين ثم أنشئ App Password وضعه في SMTP_PASS.
ADMIN_EMAIL=admin@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# SMTP_USER يُفترض أنه نفس ADMIN_EMAIL إذا تُرك فارغاً
SMTP_USER=
SMTP_PASS=your_smtp_app_password

# ── Admin WhatsApp via Twilio (optional) ────────────────────────────────────
# pip install twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886
ADMIN_WHATSAPP=+10000000000

# ── Sprint 1: Market Structure (Institutional filters) ──────────────────────
ENABLE_MARKET_STRUCTURE_FILTERS=true
ENABLE_PREMIUM_DISCOUNT_FILTER=true
ENABLE_LIQUIDITY_MAP_FILTER=true
MARKET_STRUCTURE_NO_TRADE_ZONE_PCT=0.10
MARKET_STRUCTURE_HTF_LOOKBACK=60
LIQUIDITY_OPENING_RANGE_BARS=4
ENABLE_STRUCTURAL_REJECTION_NOTIFY=true
STRUCTURAL_REJECTION_NOTIFY_COOLDOWN_SEC=1800
STRUCTURAL_REJECTION_NOTIFY_MAX_PER_CYCLE=5
FINAL_SYNC_FALLBACK_ENABLED=true
ENABLE_LIMIT_ORDER_MODE=true
LIMIT_ORDER_TTL_BARS=4
LIMIT_ORDER_BAR_MINUTES=15
LIMIT_ORDER_MOMENTUM_RETRACE=0.618
LIMIT_ORDER_MEANREV_ATR_OFFSET=0.20
LIMIT_ORDER_ALLOW_MARKET_FALLBACK=false

# ── Data Layer / Scanner v2 ───────────────────────────────────────────────────
MARKET_DATA_TIMEOUT_SEC=20
MARKET_DATA_SESSION_TTL_SEC=45
ENGINE_LOG_ROOT=logs

# ── Logging / Notifications v2 ────────────────────────────────────────────────
REJECTION_SUPPRESSION_NOTICE_COOLDOWN_SEC=1800

# ── AI Gatekeeper tuning ───────────────────────────────────────────────────────
AI_MIN_PROB_RF=62.0
AI_MIN_PROB_MOMENTUM=65.0
AI_MIN_PROB_MEANREV=64.0
AI_SOFT_OVERRIDE_CONFIDENCE=63.0
AI_SOFT_OVERRIDE_MIN_PROB=40.0
ENABLE_AI_SOFT_OVERRIDE=false
ENABLE_MS_SCORE_AI_INTEGRATION=true
MS_SCORE_AI_NEUTRAL=50.0
MS_SCORE_AI_SCALE=0.18
MS_SCORE_AI_MAX_IMPACT=8.0
EXECUTION_REJECTION_NOTIFY_COOLDOWN_SEC=600

# ── Dual Signal Profiles (Phase 8) ────────────────────────────────────────────
# SIGNAL_PROFILE: FAST or GOLDEN
SIGNAL_PROFILE=FAST
FAST_MIN_CONFIDENCE=67.0
GOLDEN_MIN_CONFIDENCE=74.0
FAST_MR_MIN_SCORE=65
GOLDEN_MR_MIN_SCORE=74
FAST_MOM_MIN_SCORE=68
GOLDEN_MOM_MIN_SCORE=78

# ── Phase 7: Deep Direction Model (optional) ─────────────────────────────────
ENABLE_DEEP_DIRECTION_MODEL=false
DEEP_DIRECTION_MODEL_KIND=lstm
DEEP_DIRECTION_TIMEFRAME=15m
DEEP_DIRECTION_SEQ_LEN=64
DEEP_DIRECTION_LABEL_HORIZON=8
DEEP_DIRECTION_LABEL_THRESHOLD=0.012
ENABLE_DEEP_DIRECTION_INFERENCE=false
DEEP_DIRECTION_INFERENCE_KIND=lstm
