GDRIVE_OAUTH_CLIENT_JSON=/root/Nasdaq_SaaS_Project/backups/client_secret_xxx.json
# GDRIVE_OAUTH_TOKEN_JSON=/path/to/gdrive_token.json
# أول مرة على VPS بدون متصفح: GDRIVE_OAUTH_CONSOLE=1 python -m utils.backup (الصق رابط إعادة التوجيه أو الكود)
# GDRIVE_OAUTH_CONSOLE=1
# GDRIVE_OAUTH_PORT=8080
# إن استخدمت service_account بدل oauth:
