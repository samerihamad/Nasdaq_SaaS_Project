# انسخ هذا الملف إلى اسم ".env" وعبّئ القيم الحقيقية على جهازك أو على الـ VPS.
# لا ترفع ملف .env إلى GitHub — هو مُستبعد في .gitignore.
# هذا الملف (.env.example) يُرفع للمستودع كقالب فقط (بدون أسرار).

# Capital.com API Configuration
CAPITAL_API_KEY=
CAPITAL_IDENTIFIER=
CAPITAL_PASSWORD=
CAPITAL_TYPE=DEMO

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=
ADMIN_CHAT_ID=
SUPPORT_USERNAME=

# ── Encryption ─────────────────────────────────────────────────────────────
ENCRYPTION_KEY=
# النسخ السحابي: gdrive أو dropbox فقط (لا تضع رابط Drive في BACKUP_PROVIDER)
BACKUP_PROVIDER=gdrive
# المعرف فقط من الرابط بعد /folders/
GDRIVE_FOLDER_ID=
# oauth = Gmail شخصي (موصى به) | service_account = Workspace/متقدم
GDRIVE_AUTH=oauth
# مثال VPS: /home/user/Nasdaq_SaaS_Project/config/client_secret....json
GDRIVE_OAUTH_CLIENT_JSON=
# GDRIVE_OAUTH_TOKEN_JSON=/path/to/gdrive_token.json
# إن استخدمت service_account بدل oauth:
GOOGLE_SERVICE_ACCOUNT_JSON=
DROPBOX_ACCESS_TOKEN=

# News API
NEWS_API_KEY=

# ── Admin Email Notifications (optional) ────────────────────────────────────
# يُرسل عند رفع العميل لصورة الدفع (ليس عند /start فقط).
# Gmail: فعّل التحقق بخطوتين ثم أنشئ App Password وضعه في SMTP_PASS.
ADMIN_EMAIL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# SMTP_USER يُفترض أنه نفس ADMIN_EMAIL إذا تُرك فارغاً
SMTP_USER=
SMTP_PASS=

# ── Admin WhatsApp via Twilio (optional) ────────────────────────────────────
# pip install twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
ADMIN_WHATSAPP=
